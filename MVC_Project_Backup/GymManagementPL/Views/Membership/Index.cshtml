@using GymManagementBLL.ViewModels.Membership
@model IEnumerable<MembershipViewModel>

<div class="container-fluid">
    <header class="bg-primary text-white rounded-3 p-4 shadow-sm mt-5 mb-4">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h2 class="mb-1 fw-semibold">Memberships</h2>
                <p class="mb-0 text-light opacity-75">All Members and Their Plans</p>
            </div>
            <div class="col text-end">
                <a asp-action="Create" class="btn btn-light">
                    <i class="fas fa-plus"></i> New Membership
                </a>
            </div>
        </div>
    </header>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle-fill me-2"></i>
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card">
        <div class="card-body">

            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-person-workspace display-1 text-muted"></i>
                    <h4 class="mt-3 text-muted">No Memberships Available</h4>
                </div>
            }
            else
            {
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>Member</th>
                            <th>Plan</th>
                            <th>Start Date</th>
                            <th>End Date</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.MemberName</td>
                                <td>@item.PlanName</td>
                                <td>@item.StartDate.ToString("dd/MM/yyyy")</td>
                                <td>@item.EndDate.ToString("dd/MM/yyyy")</td>
                                <td>
                                    @if (item.Status == "Active")
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Expired</span>
                                    }
                                </td>
                                <td>
                                    <form asp-action="Cancel" method="post" class="m-0">
                                        <input type="hidden" name="memberId" value="@item.MemberId" />
                                        <input type="hidden" name="planId" value="@item.PlanId" />
                                        <button type="submit" class="btn btn-sm btn-danger">
                                            <i class="fas fa-times"></i> Cancel
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>
